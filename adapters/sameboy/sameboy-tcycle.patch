+void GB_advance_cycles(GB_gameboy_t *gb, uint8_t cycles)
+{
+    /* morepork: with a per-T-cycle callback installed, step the machine one
+       T-cycle at a time and fire the hook after each, exposing sub-instruction
+       (PPU/timer/DIV) state. Without a callback this is a single tail call with
+       no added overhead — behaviour is identical to upstream. */
+    if (unlikely(gb->tcycle_callback)) {
+        while (cycles) {
+            advance_cycles(gb, 1);
+            gb->tcycle_callback(gb);
+            cycles--;
+        }
+    }
+    else {
+        advance_cycles(gb, cycles);
+    }
+}
